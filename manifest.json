{
  "manifest_version": 3,
  "name": "YouTube Productivity Toolkit",
  "version": "1.2.0",
  "description": "Improve your YouTube viewing experience with smart playback and productivity enhancements.",
  "author": "FlowKit Labs",

  "browser_specific_settings": {
    "gecko": {
      "id": "youtube-productivity-toolkit@flowkit-labs",
      "strict_min_version": "109.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "content_scripts": [
    {
      "matches": ["*://www.youtube.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],

  "permissions": [],
  "host_permissions": ["*://www.youtube.com/*"]
}